@using TesteASPNET.Domain.Entities
@model IEnumerable<Produto>

@{
    ViewBag.Title = "Lista de Produtos";
}

<h2>Lista de Produtos</h2>

<p>
    <a href="@Url.Action("Create")" class="btn btn-primary">Novo Produto</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>@Html.DisplayNameFor(model => model.Nome)</th>
            <th>@Html.DisplayNameFor(model => model.Preco)</th>
            <th>@Html.DisplayNameFor(model => model.Estoque)</th>
            <th>@Html.DisplayNameFor(model => model.DataAtualizacao)</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Nome</td>
                <td>@item.Preco.ToString("C")</td>
                <td>@item.Estoque</td>
                <td>@item.DataAtualizacao.ToString("g")</td>
                <td>
                    <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-sm btn-warning">Editar</a>
                    @using (Html.BeginForm("DeleteConfirmed", "Produto", new { id = item.Id }, FormMethod.Post, new { style = "display:inline" }))
                    {
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Confirma excluir?');">Excluir</button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
